# Fernet Encryption Key
# Generate a new key by running: python src/encryption.py
# Copy the generated key and paste it below
FERNET_KEY=your_fernet_key_here

# GitHub OAuth app credentials
# Create an OAuth app at: https://github.com/settings/developers
# 
# For local development:
#   Callback URL: http://localhost:8080/oauth_callback
#
# For Replit deployment:
#   1. Deploy to Replit first to get your URL (e.g., https://your-project.replit.dev)
#   2. Add callback: https://your-project.replit.dev/oauth_callback
#   3. Update GITHUB_REDIRECT_URL below
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_REDIRECT_URL=http://localhost:8080/oauth_callback
